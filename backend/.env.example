# Backend environment template (safe to commit)
# Copy to backend/.env and fill with real values.

# AI providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Sports data provider
API_FOOTBALL_KEY=your_api_football_key

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_PHONE_NUMBER=whatsapp:+1234567890

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Alerts
MIN_CONFIDENCE_ALERT=65
# Base live poll interval (seconds). Keep conservative by default for quota safety.
LIVE_POLL_INTERVAL=30
# Optional fast mode while live matches exist; disabled unless ENABLE_ADAPTIVE_LIVE_POLL=true
ENABLE_ADAPTIVE_LIVE_POLL=false
LIVE_POLL_INTERVAL_WHEN_LIVE=12
# Quota heartbeat (ms). Set 0 to disable.
QUOTA_GUARD_HEARTBEAT_MS=15000
TRACKED_LEAGUES=1,2,3,4,10,39,78,135,140,1222
